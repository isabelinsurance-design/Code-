# ============================================================
#  TODO ISABEL — LA DIRECTORA · Configuración del servidor
#  Copia este archivo a ".env" y rellena tus valores reales.
#  NUNCA subas el archivo .env a GitHub (ya está en .gitignore).
# ============================================================

# --- Anthropic (el cerebro de los coaches) ---
ANTHROPIC_API_KEY=sk-ant-...
# Modelo de La Directora. Opus 4.7 es el más inteligente.
# Si quieres bajar costos, puedes cambiar a claude-sonnet-4-6.
DIRECTORA_MODEL=claude-opus-4-7

# --- Twilio (manda y recibe WhatsApp) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Tu número de WhatsApp de Twilio (con el prefijo whatsapp:)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# El WhatsApp de Isabel (a donde llegan los briefings de la mañana)
ISABEL_WHATSAPP=whatsapp:+1...
# El WhatsApp/SMS de Sami (tu asistente). Puede ser whatsapp:+1... o +1...
SAMI_WHATSAPP=whatsapp:+1...

# --- Seguridad del webhook ---
# El servidor verifica que cada mensaje entrante venga de Twilio.
# Está ENCENDIDO por defecto; ponlo en "false" SOLO en dev local.
TWILIO_REQUIRE_SIGNATURE=true
# URL pública de tu servidor (la que registras en Twilio), p.ej.
# https://tu-app.up.railway.app  — necesaria para verificar la firma.
PUBLIC_URL=

# --- Email (OPCIONAL — para que La Directora lea y mande correos) ---
# Usa una "contraseña de aplicación" de Gmail (no tu contraseña normal):
# https://myaccount.google.com/apppasswords
GMAIL_USER=isabel.insurance@gmail.com
GMAIL_APP_PASSWORD=
# A dónde firma los correos
ISABEL_NAME=Isabel Fuentes

# --- Web app / PWA (REQUIRED si quieres usar el dashboard en /app) ---
# Password único para entrar a la app. Lo escribes una vez en iPhone/laptop,
# dura 30 días. APP_SECRET es la llave HMAC que firma el cookie — genera
# uno random con: openssl rand -base64 32
APP_PASSWORD=
APP_SECRET=

# --- Push notifications (OPCIONAL — para que el iPhone suene cuando Athena pinga) ---
# Genera las llaves UNA VEZ con:
#   cd server && node src/push.js --generate-keys
# Pega los 3 valores aquí. Requiere PWA instalada en iPhone primero
# ("Compartir → Añadir a pantalla de inicio") para que Safari permita el push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:isabel.insurance@gmail.com

# --- GitHub (OPCIONAL — para que Athena cree issues con sus mejoras propuestas) ---
# Crea un Personal Access Token en https://github.com/settings/tokens con scope "repo"
# o "public_repo" si el repo es público. Athena usa proponer_mejora para abrir issues
# con label "athena-propuesta" que Claude Code recoge para convertir en PRs.
GITHUB_TOKEN=
GITHUB_REPO=isabelinsurance-design/Code-

# --- LUNA bridge (CRÍTICO para Pilar Medicare) ---
# LUNA es el workspace AI del negocio Medicare (Bluehost PHP+MySQL).
# Pilar (especialista Medicare de Athena) se conecta vía estos.
# El equipo LUNA genera y comparte la API_KEY — pegar acá directo.
LUNA_BASE_URL=https://withisabelfuentes.com/luna/luna_api.php
LUNA_API_KEY=

# --- Horario del briefing de la mañana (zona horaria de Isabel) ---
TIMEZONE=America/Los_Angeles
MORNING_BRIEFING_CRON=30 6 * * *
PORT=3000
